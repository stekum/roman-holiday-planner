# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment (explicit — don't rely on *.local alone)
.env.local
.env.*.local
# Firebase Cloud Functions param-file (created by `firebase deploy`) —
# stores project-scoped param values and may contain endpoints / addresses
functions/.env.*

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Playwright test artifacts (local only)
.playwright-results/

# Claude Code per-session noise (lock-files, ad-hoc local settings).
# Note: .claude/agents/, .claude/settings.json sind committed (geteilte
# Team-Setups). Nur scheduled_tasks.lock + settings.local.json sind lokal.
.claude/scheduled_tasks.lock
.claude/settings.local.json

# Firebase Admin SDK service account — NEVER commit
service-account*.json
**/service-account*.json
*-credentials.json
**/*-credentials.json
