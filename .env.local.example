# --- Roman Holiday Planner — Env Template ---
# Copy this file to .env.local and fill in the values.
# .env.local is git-ignored.

# Google Maps API key.
# Required for: Maps, Places Autocomplete, Directions (Tagesplaner).
# Create in Google Cloud Console → APIs & Services → Credentials.
# IMPORTANT — restrict the key:
#   - Application restriction: HTTP referrer
#       https://<your-github-username>.github.io/roman-holiday-planner/*
#       http://localhost:5173/*
#   - API restrictions: Maps JavaScript API, Places API, Directions API
#   - Quotas: set daily caps on all three APIs (e.g. 500/day)
VITE_GOOGLE_MAPS_API_KEY=

# --- Firebase (für die kollaborative Beta-Version) ---
# Aus Firebase Console → Project Settings → Your apps → Web app config
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Optionaler Shared-Namespace — erlaubt später mehrere getrennte Gruppen unter
# derselben Firebase-Instanz. Default: 'default'.
VITE_FIREBASE_WORKSPACE_ID=default

# --- Gemini AI ---
# Kein Client-Key nötig! Gemini läuft serverseitig über Firebase AI Logic.
# Konfiguration: Firebase Console → AI Logic → Gemini aktivieren.

# --- Google Analytics (#123) ---
# GA4 Measurement-ID aus Firebase Console → Project Settings → Integrations
# → Google Analytics. Format: G-XXXXXXXXXX.
# Leerlassen deaktiviert Tracking vollständig. Opt-Out pro Client in Console:
#   localStorage.setItem('disableAnalytics', '1'); location.reload();
VITE_GA_MEASUREMENT_ID=

# --- E2E Testing (Playwright auto-login) ---
# Pfad zum Firebase-Service-Account-JSON (Admin SDK, für Custom-Token-Minting).
# NICHT committen. Download: Firebase Console → Project Settings → Service
# Accounts → Generate new private key. Fallback: ./service-account.json im
# Projekt-Root wird automatisch erkannt.
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
